# Copy this file to .env and fill in your values

# Required: Spotify sp_dc cookie
# Get this from your browser: open spotify.com, open DevTools > Application > Cookies, copy the sp_dc value
SP_DC=your_sp_dc_cookie_here

# Required: Path to your Widevine .wvd device file (for MP4/AAC fallback)
WVD_PATH=./device.wvd

# Recommended: Spotify API credentials (avoids rate limits on search/metadata)
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# API key for protected endpoints (POST /download, GET /download/:id)
API_KEY=your_api_key_here

# Optional: HTTP proxy in ip:port:username:password format
# SPOT_PROXY=proxy.example.com:8080:user:pass

# Optional: Python executable path (for Widevine helper)
# PYTHON_CMD=python3

# Optional: Download directly into cache/presence/ instead of cache/music/ (saves ~50% disk)
NO_MUSIC_CACHE=1

# Optional: Never delete cached audio files (disables TTL expiry and LRU eviction)
NO_EVICT=1
